# Supply-chain attack hardening
# Always pin exact versions — no ^ or ~ range installs
save-exact=true

# Run npm audit on every install to catch known CVEs
audit=true

# Audit level: fail the install if any HIGH or CRITICAL vulnerability is found
audit-level=high

# Enforce use of the lockfile to prevent unpinned resolution
package-lock=true

# Prefer offline resolution when possible (avoids network-based substitution)
prefer-offline=false

# Block post-install scripts from dependencies (supply-chain attack vector)
ignore-scripts=true
legacy-peer-deps=true
